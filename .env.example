# ===========================================
# Claude Code Statusline - 环境变量配置
# ===========================================
#
# 将本文件复制为 .env 并根据需要填写实际值：
#   cp .env.example .env
#
# 状态栏脚本会在启动时加载 .env 中的变量。
# 注意：实际生效的 API key 需要设置在脚本能读取到的地方，
# 具体加载方式请参考 install.sh 中的相关配置。
#
# 各变量的 provider 说明见下方的分组注释。

# ---- 通用 ----
# 状态栏安装目录（覆盖默认的 ~/.claude/statusline）
# CLAUDE_STATUSLINE_DIR=/path/to/statusline


# ===========================================
# API Balance 查询提供商
# ===========================================

# === DeepSeek ===
# provider: deepseek
# 端点: https://api.deepseek.com/user/balance
ANTHROPIC_AUTH_TOKEN=sk-your-deepseek-api-key-here
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# === Kimi / 月之暗面 ===
# provider: kimi
# 端点: https://api.kimi.com/coding/v1/usages
ANTHROPIC_API_KEY=sk-your-kimi-api-key-here

# === 小米默默 ===
# provider: xiaomimimo
# 端点: https://platform.xiaomimimo.com/api/v1/tokenPlan/usage
# 该 provider 无独立的 token_env 字段，需通过其他方式配置鉴权

# === SCNet ===
# provider: scnet
# 端点: https://www.scnet.cn/acx/charge/flow/llmapi/resource/list
ANTHROPIC_AUTH_TOKEN=your-scnet-token-here

# === SCNet 套餐计划 ===
# provider: scnet-tp
# 端点: https://www.scnet.cn/acx/charge/account/currentuser/tokenplan/list
ANTHROPIC_AUTH_TOKEN=your-scnet-token-here

# === 火山引擎 / Volces ===
# provider: volces
# 端点: https://console.volcengine.com/api/top/ark/cn-beijing/2024-01-01
ANTHROPIC_AUTH_TOKEN=your-volces-session-token-here
